      "id": "filesystem",
      "name": "文件系统",
      "nameEn": "Filesystem",
      "description": "读取、写入和管理本地文件系统，支持目录遍历、文件搜索、批量操作",
      "category": "file",
      "tags": [
        "文件",
        "文件系统",
        "读取",
        "写入",
        "目录"
      ],
      "source": {
        "type": "npm",
        "package": "@modelcontextprotocol/server-filesystem",
        "registry": "https://npmjs.com/package/@modelcontextprotocol/server-filesystem"
      },
      "configTemplate": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-filesystem",
          "${path}"
        ],
        "env": {}
      },
      "configParams": [
        {
          "name": "path",
          "type": "string",
          "required": true,
          "description": "允许访问的根目录路径",
          "default": "~/Documents",
          "example": "C:/Users/YourName/Projects"
        }
      ],
      "capabilities": [
        "读取文件",
        "写入文件",
        "列出目录",
        "搜索文件",
        "创建目录"
      ],
      "requirements": {
        "node": ">=18.0.0"
      },
      "links": {
        "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/filesystem",
        "npm": "https://npmjs.com/package/@modelcontextprotocol/server-filesystem"
      },
      "verified": true,
      "popularity": 5
    },
